IF
	IsOverMe([PC])
	PartyHasItem("MISC45")  // Rogue Stone
	Global("RoguestoneWarn","GLOBAL",0)
THEN
	RESPONSE #100
		SaveGame(0)
		SetGlobal("RoguestoneWarn","GLOBAL",1)
		DisplayString(Myself,@87)  //  @87=~The Rogue Stone in your backpack starts humming faintly. It is reacting to something here in this area. Somewhere in the vicinity.~
END
