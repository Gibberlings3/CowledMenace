IF
    NumberOfTimesTalkedTo(0)
    !AreaCheck("DX#002")
    See([PC])
THEN
    RESPONSE #100
        Wait(1)
        StartDialogueNoSet([PC])
END

IF
    NumberOfTimesTalkedTo(0)
    AreaCheck("DX#002")
    See([PC])
    Dead("DX#DEMI")  // Zallanora the Demilich
THEN
    RESPONSE #100
        Wait(3)
        StartDialogueNoSet([PC])
END

