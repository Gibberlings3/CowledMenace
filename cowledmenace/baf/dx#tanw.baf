IF
    Allegiance(Myself,ENEMY)
    Detect([PC])
    !AreaCheck("ar0500")  // Bridge District
    Exists("tanwiz1")  // Vellin Dahn
THEN
    RESPONSE #100
        ForceSpell(Myself,POOF_GONE)  // SPIN660.SPL (Teleport)
END

IF
    NumberOfTimesTalkedTo(0)
    Detect([PC])
THEN
    RESPONSE #100
        StartDialogueNoSet(LastSeenBy(Myself))
END
